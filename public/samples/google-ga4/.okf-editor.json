        {
          "key": "title",
          "kind": "string",
          "required": true
        },
        {
          "key": "description",
          "kind": "text"
        },
        {
          "key": "resource",
          "kind": "string"
        },
        {
          "key": "tags",
          "kind": "tags"
        },
        {
          "key": "timestamp",
          "kind": "string"
        }
      ]
    },
    "Reference": {
      "label": "Reference",
      "fields": [
        {
          "key": "title",
          "kind": "string",
          "required": true
        },
        {
          "key": "description",
          "kind": "text"
        },
        {
          "key": "resource",
          "kind": "string"
