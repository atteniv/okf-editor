{
  "$schema": "https://raw.githubusercontent.com/atteniv/okf-editor/main/schemas/okf-editor.schema.json",
  "types": {
    "BigQuery Dataset": {
      "label": "BigQuery Dataset",
      "fields": [
        {
          "key": "title",
          "kind": "string",
